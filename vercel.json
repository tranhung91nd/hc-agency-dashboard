{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "zalo.hc-agency.online" }],
      "destination": "/demos/landing-zalo-ai.html"
    },
    { "source": "/ads/:path*", "destination": "/index.html" },
    { "source": "/staff/:path*", "destination": "/index.html" },
    { "source": "/clients/:path*", "destination": "/index.html" },
    { "source": "/finance/:path*", "destination": "/index.html" },
    { "source": "/alert/:path*", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/team", "destination": "/index.html" }
  ]
}
